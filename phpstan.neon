parameters:
    level: 8
    paths:
        - app/Domain
        - app/Infrastructure
        - app/Libraries
        - app/Models
        - app/Controllers
        - tests
    excludePaths:
        - app/Config/Constants.php
        - app/Views
        # CodeIgniter scaffolded test directories shipped with the framework
        # template (tests/_support, tests/_skipped, tests/session, tests/database,
        # tests/unit). They are example stubs, not our project tests; our
        # tests live under tests/Unit, tests/Integration, tests/Feature.
        - tests/_support
        - tests/_skipped
        - tests/session
        - tests/database
        - tests/unit
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            identifier: trait.unused
            path: app/Models/Cookie/Traits/
        # RegisterRoutesNoop is a scaffolding helper for future
        # DomainServiceProviders that don't expose HTTP routes. The
        # existing 3 providers all override registerRoutes() with real
        # implementations, so the trait is intentionally unused today
        # but kept on hand for new domains.
        -
            identifier: trait.unused
            path: app/Infrastructure/ServiceProvider/RegisterRoutesNoop.php
        -
            identifier: constant.notFound
            path: app/Config/
        -
            identifier: return.type
            path: app/Config/Services.php
        -
            identifier: argument.type
            path: app/Config/Services.php
        -
            identifier: function.notFound
            path: app/Config/
        -
            identifier: property.defaultValue
            path: app/Config/Filters.php
        -
            identifier: ternary.shortNotAllowed
            path: app/Config/App.php
        -
            identifier: arrayFilter.strict
            path: app/Config/App.php
        # Tests use the documented `$this->assertX()` PHPUnit pattern,
        # but the underlying methods are static on Assert. phpstan-strict's
        # staticMethod.dynamicCall fires on every assertion — it's a
        # stylistic warning, not a real bug, so it's silenced for tests.
        -
            identifier: staticMethod.dynamicCall
            path: tests/
        # `$this->assertTrue(true)` is fine in tests where the goal is
        # the dispatch happened, not what the assertion proves.
        -
            identifier: method.alreadyNarrowedType
            path: tests/
        # PHPUnit's expectExceptionMessage/expectExceptionCode accept
        # positional args; named-arg refactors are out of scope for tests.
        -
            identifier: argument.named
            path: tests/
        # Tests routinely set up mock objects and arrays that PHPStan can't
        # type narrowly without exhaustive @phpstan-* annotations. We keep
        # only the small set of identifiers that genuinely don't apply to
        # tests; everything else MUST be fixed in the test source.
        -
            identifier: missingType.iterableValue
            path: tests/
        -
            identifier: missingType.parameter
            path: tests/
        -
            identifier: missingType.return
            path: tests/
        -
            identifier: missingType.generics
            path: tests/
        -
            identifier: property.notFound
            path: tests/
        -
            identifier: method.notFound
            path: tests/
        -
            identifier: method.nonObject
            path: tests/
        -
            identifier: function.notFound
            path: tests/
        -
            identifier: function.alreadyNarrowedType
            path: tests/
        -
            identifier: offsetAccess.notFound
            path: tests/
        -
            identifier: property.phpDocType
            path: tests/
        -
            identifier: argument.type
            path: tests/
        -
            identifier: return.type
            path: tests/
        -
            identifier: ternary.shortNotAllowed
            path: tests/
        -
            identifier: ternary.condNotBoolean
            path: tests/
        -
            identifier: property.onlyWritten
            path: tests/
        # CodeIgniter's PSR-3 logger declarations exceed PHPStan's call-site
        # type narrowing — the bus middleware uses `mixed` for log values.
        -
            identifier: argument.templateType
            path: app/Infrastructure/Bus/Middleware/
        # The docblock generator (temp/generate-docblocks.php) inserts @param
        # array<mixed> on interfaces with bare `array` signatures. Existing
        # subclass overrides that specify a narrower array<string, X> were
        # technically LSP violations all along, but the missing @param on the
        # interface hid them. Until the subclasses are widened (or the
        # interface signatures are narrowed), accept these three cases.
        -
            identifier: method.childParameterType
            path: tests/Integration/Jobs/TestJobHandler.php
        -
            identifier: method.childParameterType
            path: tests/Unit/Infrastructure/Bulk/BulkImportRunnerTest.php
        -
            identifier: method.childParameterType
            path: tests/Unit/Infrastructure/Http/Client/OutboundHttpClientTest.php
        # LocaleResolver::userPreferredLocale() carries a pre-existing
        # @phpstan-ignore-next-line note to keep ?string return type for a
        # future hook. The docblock generator added an explicit @return that
        # turned the latent suppression into a hard `return.unusedType` because
        # the implementation currently only returns null. The annotation is a
        # deliberate placeholder — kept, ignored here.
        -
            identifier: return.unusedType
            path: app/Infrastructure/I18n/LocaleResolver.php
        # CookieQueryRepository::__construct() / connection() deliberately
        # drop the BaseConnection<TConnection, TResult> template parameters
        # (closes 06/F15 — the over-specified union was bleeding through
        # test injection sites for no payoff at runtime). The framework
        # types are still honoured; only the generic adornment is omitted.
        -
            identifier: missingType.generics
            path: app/Domain/Cookie/Repositories/CookieQueryRepository.php
    bootstrapFiles:
        - phpstan-bootstrap.php

includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-phpunit/rules.neon
