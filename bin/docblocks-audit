#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * docblocks:audit — fail the build on placeholder / stub docblocks.
 *
 * Detects two kinds of unreviewed docblock content shipped by the
 * companion generator (bin/docblocks-generate):
 *
 *   1. STUB (placeholder) — a docblock whose first prose line is a
 *      single word ending with a period that just restates the
 *      symbol name. Example emitted by bin/docblocks-generate:
 *
 *          /\**
 *           * __construct.
 *           *\/
 *          public function __construct(...) { ... }
 *
 *      Multi-line variant (also detected):
 *
 *          /\**
 *           * raiseConcurrentModification.
 *           *
 *           * @throws DomainException
 *           *\/
 *          private function raiseConcurrentModification(...): never
 *
 *      These satisfy Squiz.Commenting.{Function,Class}Comment ("a
 *      docblock exists") but carry zero information: they restate
 *      the symbol name and tell a reader nothing about the
 *      contract, behaviour, or invariants. The audit brief at
 *      .audit/round3/16-documentation-docblocks.md (F1) enumerated
 *      26 such stubs across the Cookie surface; this rule prevents
 *      them from being reintroduced.
 *
 *   2. LEGACY MARKER — the explicit "@todo Auto-generated docblock
 *      — review and replace this description." line that the
 *      generator emits to mark a brand-new placeholder. Catching
 *      it here is the explicit re-arming of the marker contract
 *      called out by REVIEW-slevomat.md req. #3.
 *
 * Exit codes:
 *   0  — no stubs and no legacy markers found in the supplied scope.
 *   1  — one or more occurrences exist. Prints a "file:line / kind /
 *         symbol" table and a reminder to replace each with real prose.
 *
 * Usage:
 *   php bin/docblocks-audit                      # walks app/ by default
 *   php bin/docblocks-audit path/to/dir [...]    # explicit path(s)
 *   php bin/docblocks-audit --quiet              # exit code only
 *
 * The `composer docblocks:audit` wrapper scopes the script to the area
 * the project has actively cleaned (today: app/Domain/Cookie); later
 * epics widen the scope domain-by-domain.
 *
 * Why this exists as a custom script (and not a PHPCS sniff):
 *   PHPCS Squiz.Commenting sniffs check that a docblock EXISTS but
 *   cannot evaluate whether the prose is meaningful. Slevomat's
 *   Commenting.UselessFunctionDocComment is close but flags
 *   docblocks-that-only-repeat-the-signature, which is not what we
 *   want (we keep @param/@return tags); it does not catch the
 *   "single word that restates the method name" pattern that the
 *   generator emits. A short PHP script catches the exact pattern
 *   with zero false positives.
 */

const LEGACY_MARKER = '@todo Auto-generated docblock — review and replace this description.';

$quiet = false;
$paths = [];
foreach (array_slice($argv, 1) as $arg) {
    if ($arg === '--quiet' || $arg === '-q') {
        $quiet = true;
        continue;
    }
    $paths[] = $arg;
}
if ($paths === []) {
    $paths = ['app'];
}

$root = dirname(__DIR__);

/** @var list<array{file: string, line: int, kind: string, symbol: string}> $hits */
$hits = [];

foreach ($paths as $path) {
    $abs = $root . DIRECTORY_SEPARATOR . ltrim($path, '/\\');
    if (!file_exists($abs)) {
        fwrite(STDERR, sprintf("docblocks:audit: path not found: %s\n", $abs));
        exit(1);
    }
    if (is_file($abs)) {
        scanFile($abs, $hits, $root);
        continue;
    }
    $it = new RecursiveIteratorIterator(new RecursiveDirectoryIterator($abs));
    foreach ($it as $f) {
        if ($f instanceof SplFileInfo && $f->isFile() && $f->getExtension() === 'php') {
            scanFile($f->getPathname(), $hits, $root);
        }
    }
}

if ($hits === []) {
    if (!$quiet) {
        echo "✓ docblocks:audit — no placeholder docblocks or legacy markers found.\n";
    }
    exit(0);
}

if ($quiet) {
    exit(1);
}

printf(
    "⚠ docblocks:audit — %d placeholder docblock(s) need a real description:\n\n",
    count($hits)
);
printf("  %-60s  %-10s  %s\n", 'file:line', 'kind', 'symbol');
printf("  %s\n", str_repeat('-', 90));
foreach ($hits as $hit) {
    printf(
        "  %-60s  %-10s  %s\n",
        $hit['file'] . ':' . $hit['line'],
        $hit['kind'],
        $hit['symbol']
    );
}

echo "\nWhat to do:\n";
echo "  - STUB:   replace the single-word docblock prose with a one-line\n";
echo "            description of what the method/class/constructor does and\n";
echo "            (where relevant) its invariants. Examples in\n";
echo "            .audit/round3/16-documentation-docblocks.md / F1.\n";
echo "  - LEGACY: remove the '@todo Auto-generated docblock — review and\n";
echo "            replace this description.' line and replace it with prose.\n";
exit(1);

/**
 * Scan one file for both stub and legacy-marker hits.
 *
 * @param string                                                             $path Absolute path of the file to scan.
 * @param list<array{file: string, line: int, kind: string, symbol: string}> $hits Accumulator passed by reference.
 * @param string                                                             $root Project root, stripped from paths for compact output.
 */
function scanFile(string $path, array &$hits, string $root): void
{
    $contents = file_get_contents($path);
    if ($contents === false) {
        return;
    }
    $rel = str_starts_with($path, $root . DIRECTORY_SEPARATOR)
        ? substr($path, strlen($root) + 1)
        : $path;

    $lines = explode("\n", $contents);

    // 1. Legacy "@todo Auto-generated docblock" markers.
    foreach ($lines as $i => $line) {
        if (str_contains($line, LEGACY_MARKER)) {
            $hits[] = [
                'file' => $rel,
                'line' => $i + 1,
                'kind' => 'LEGACY',
                'symbol' => '(@todo marker)',
            ];
        }
    }

    // 2. STUB detection — placeholder docblock whose FIRST prose line is a
    // single word ending with a period (just restating the symbol name).
    // Matches both the single-line shape and the multi-line shape where
    // @param/@return/@throws tags follow. The line BEFORE the prose must be
    // a bare `/**` opener so inline-comment false positives are impossible.
    $count = count($lines);
    for ($i = 1; $i < $count; $i++) {
        $prev = $lines[$i - 1];
        $curr = $lines[$i];

        if (!isPlaceholderOpen($prev)) {
            continue;
        }
        if (preg_match('#^\s*\*\s*(\w+)\.\s*$#', $curr, $m) !== 1) {
            continue;
        }
        $hits[] = [
            'file' => $rel,
            'line' => $i + 1,
            'kind' => 'STUB',
            'symbol' => $m[1],
        ];
    }
}

/**
 * @param string $line Line to inspect.
 * @return bool        True when the line is a bare docblock opener (`/**` plus optional trailing whitespace).
 */
function isPlaceholderOpen(string $line): bool
{
    return preg_match('#^\s*/\*\*\s*$#', $line) === 1;
}
