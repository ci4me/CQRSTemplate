{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CI": "false",
    "XDEBUG_MODE": "coverage,debug",
    "ENVIRONMENT": "development"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(test:*)",
      "Bash(composer:*)",
      "Bash(vendor/bin/phpstan:*)",
      "Bash(vendor/bin/phpcs:*)",
      "Bash(vendor/bin/phpcbf:*)",
      "Bash(vendor/bin/phpunit:*)",
      "Bash(php spark:*)",
      "Bash(php -l:*)",
      "Bash(php -r:*)",
      "Bash(mysql:*)",
      "Bash(sudo mysql:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(/dev/null)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)",
      "Bash(gh api:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git tag:*)",
      "Bash(git remote:*)",
      "Bash(git config --local:*)",
      "Bash(gitleaks:*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "TodoWrite(*)",
      "Task(*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(drop database:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force)",
      "Bash(git push * -f)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push *--no-verify*)",
      "Bash(git reset --hard origin/*)",
      "Bash(git reset --hard upstream/*)",
      "Bash(git config --global*)",
      "Bash(git config --system*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref -d *)",
      "Bash(git checkout --orphan*)",
      "Bash(rm .git*)",
      "Bash(rm -r .git*)",
      "Bash(rm -rf .git*)",
      "Write(.env)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(*.p12)",
      "Write(secrets/**)"
    ],
    "ask": [
      "Bash(git rebase -i*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo edit *--visibility*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/git-guard.sh"
          }
        ]
      }
    ]
  }
}
