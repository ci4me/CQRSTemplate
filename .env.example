#--------------------------------------------------------------------
# Example Environment Configuration file
#
# This file can be used as a starting point for your own
# custom .env files, and contains most of the possible settings
# available in a default install.
#
# By default, all of the settings are commented out. If you want
# to override the setting, you must un-comment it by removing the '#'
# at the beginning of the line.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------

# Force HTTPS (automatically enabled in production, can be overridden)
# FORCE_HTTPS = false

# Trusted Proxy Configuration
# SECURITY: Configure trusted proxy IPs to prevent X-Forwarded-For spoofing
# Format: comma-separated list of IP addresses or CIDR ranges
# Examples:
#   TRUSTED_PROXIES = '10.0.1.200,192.168.5.0/24'
#   TRUSTED_PROXIES = '172.31.0.0/16'
# Leave empty if not behind a proxy
# TRUSTED_PROXIES = ''
# PROXY_HEADER = 'X-Forwarded-For'

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'
# If you have trouble with `.`, you could also use `_`.
# app_baseURL = ''
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = your_database_name
database.default.username = your_database_user
database.default.password = your_database_password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Database TLS/SSL Configuration (recommended for production)
# Uncomment and configure if your MySQL server uses TLS
# database.default.encrypt.ssl_key = /path/to/client-key.pem
# database.default.encrypt.ssl_cert = /path/to/client-cert.pem
# database.default.encrypt.ssl_ca = /path/to/ca-cert.pem
# database.default.encrypt.ssl_verify = true

# If you use MySQLi as tests, first update the values of Config\Database::$tests.
database.tests.hostname = localhost
database.tests.database = your_test_database
database.tests.username = your_test_user
database.tests.password = your_test_password
database.tests.DBDriver = MySQLi
database.tests.DBPrefix =
database.tests.charset = utf8mb4
database.tests.DBCollat = utf8mb4_general_ci
database.tests.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# Generate with: php spark key:generate
# Keep this secret! Never commit to version control
encryption.key = hex2bin:YOUR_ENCRYPTION_KEY_HERE

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

#--------------------------------------------------------------------
# AUTHENTICATION (JWT)
#--------------------------------------------------------------------

# JWT Secret Key - REQUIRED - Generate a secure random 48+ byte hex string
# SECURITY: Generate with: openssl rand -hex 48
# CRITICAL: Never commit production secrets to version control
# EXAMPLE: JWT_SECRET_KEY = '96-character-hex-string-from-openssl-rand-hex-48'
JWT_SECRET_KEY = 'REPLACE_WITH_STRONG_SECRET_GENERATE_WITH_openssl_rand_hex_48'

# JWT Secret Rotation - Old secret for graceful rotation (7-day overlap)
# PROCEDURE:
# 1. Generate new secret: openssl rand -hex 48
# 2. Set JWT_SECRET_KEY_OLD to current JWT_SECRET_KEY
# 3. Set JWT_SECRET_KEY to new secret
# 4. Wait 7 days (allows all old tokens to expire or be refreshed)
# 5. Remove JWT_SECRET_KEY_OLD from environment
# NOTE: Uncomment only during rotation period
# JWT_SECRET_KEY_OLD = 'previous-secret-during-rotation'

# Access token TTL in seconds (default: 3600 = 1 hour)
AUTH_TOKEN_TTL = 3600

# Refresh token TTL in seconds (default: 2592000 = 30 days)
AUTH_REFRESH_TOKEN_TTL = 2592000

# Device Fingerprint Validation
# SECURITY: Detects session hijacking by validating device consistency
# Grace period allows device fingerprint changes within X minutes (e.g., dynamic IP)
# Set to 0 to enforce strict device validation (no grace period)
# AUTH_DEVICE_FINGERPRINT_GRACE_PERIOD = 300

# Idle Timeout
# SECURITY: Automatically revokes sessions after period of inactivity (PCI-DSS requirement)
# Default: 1800 seconds (30 minutes) - PCI-DSS recommends 15 minutes
# Set to 0 to disable idle timeout (not recommended for production)
# AUTH_IDLE_TIMEOUT_SECONDS = 1800

#--------------------------------------------------------------------
# EMAIL / SMTP
#--------------------------------------------------------------------

# SMTP Configuration for Password Reset and Notifications
# SECURITY: Required for password reset functionality (CR-6.1)

# SMTP Host (e.g., smtp.gmail.com, smtp.sendgrid.net, smtp.mailtrap.io)
# EMAIL_SMTP_HOST = 'smtp.mailtrap.io'

# SMTP Port (587 for TLS, 465 for SSL, 25 for unencrypted - not recommended)
# EMAIL_SMTP_PORT = 587

# SMTP Username
# EMAIL_SMTP_USER = 'your_smtp_username'

# SMTP Password
# EMAIL_SMTP_PASSWORD = 'your_smtp_password'

# SMTP Encryption (tls, ssl, or leave empty for none)
# EMAIL_SMTP_ENCRYPTION = 'tls'

# From Address (sender email address)
# EMAIL_FROM_ADDRESS = 'noreply@yourdomain.com'

# From Name (sender display name)
# EMAIL_FROM_NAME = 'Your App Name'

#--------------------------------------------------------------------
# REDIS CACHE
#--------------------------------------------------------------------

# Redis Configuration for Caching and Rate Limiting
# SECURITY: Redis provides atomic operations preventing race conditions
# PERFORMANCE: Significantly faster than file-based cache
# RECOMMENDED: Use Redis in production for better security and performance

# Redis connection settings
# CACHE_REDIS_HOST = '127.0.0.1'
# CACHE_REDIS_PORT = 6379
# CACHE_REDIS_PASSWORD = ''
# CACHE_REDIS_DATABASE = 0
# CACHE_REDIS_TIMEOUT = 0

# Redis Connection Pooling (optional, for high-traffic applications)
# CACHE_REDIS_PERSISTENT = false
# CACHE_REDIS_PERSISTENT_ID = 'ci4_cache'
