<?xml version="1.0"?>
<ruleset name="CodeIgniter4 CQRS Coding Standard">
    <description>PSR-12 + Slevomat Coding Standard with Clean Code enforcement</description>

    <!-- Files to check -->
    <file>app/Domain</file>
    <file>app/Infrastructure</file>
    <file>app/Controllers</file>
    <file>tests</file>

    <!-- Exclude patterns -->
    <exclude-pattern>*/Database/Migrations/*</exclude-pattern>
    <exclude-pattern>*/Database/Seeds/*</exclude-pattern>
    <exclude-pattern>*/Views/*</exclude-pattern>
    <exclude-pattern>*/Config/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/writable/*</exclude-pattern>
    <!-- NOTE: `app/Infrastructure/Persistence/*` used to be excluded here,
         which silently skipped CookieRepository / UserRepository / the
         CookieReadModelRepository / DatabaseTokenBlacklistService. The
         exclusion is removed so the repositories are PSR-12 + Slevomat
         clean. -->
    <!-- CodeIgniter scaffolded test dirs (lowercase) shipped with the
         framework template — example stubs, not our project tests.
         The real test directories are PascalCase (tests/Unit,
         tests/Integration, tests/Feature, tests/Support). -->
    <exclude-pattern>tests/_support/*</exclude-pattern>
    <exclude-pattern>tests/_skipped/*</exclude-pattern>
    <exclude-pattern>tests/session/*</exclude-pattern>
    <exclude-pattern>tests/database/*</exclude-pattern>
    <exclude-pattern>tests/unit/*</exclude-pattern>

    <!-- Arguments -->
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="parallel" value="80"/>
    <arg value="np"/>

    <!-- PSR-12 Coding Standard -->
    <rule ref="PSR12">
        <!-- Allow snake_case test method names in test files -->
        <exclude name="PSR1.Methods.CamelCapsMethodName.NotCamelCaps"/>
    </rule>

    <!-- Slevomat Coding Standard -->

    <!-- Enforce strict types declaration -->
    <rule ref="SlevomatCodingStandard.TypeHints.DeclareStrictTypes">
        <properties>
            <property name="linesCountBeforeDeclare" value="1"/>
            <property name="linesCountAfterDeclare" value="1"/>
            <property name="spacesCountAroundEqualsSign" value="0"/>
        </properties>
    </rule>

    <!-- Require type hints -->
    <rule ref="SlevomatCodingStandard.TypeHints.ParameterTypeHint">
        <!-- Exclude API controllers - CodeIgniter parent class doesn't have typed parameters -->
        <exclude-pattern>app/Controllers/Api/*Controller.php</exclude-pattern>
        <!-- Exclude AbiSageIntacct library - third-party namespace with different conventions -->
        <exclude-pattern>app/Libraries/AbiSageIntacct/*</exclude-pattern>
        <!-- We want FULL docblocks for Intelephense (Squiz.Commenting.FunctionComment
             requires @param on every parameter). Slevomat's "useless annotation"
             check would call those duplicate, so we silence it where the duplication
             is mandated by the docblock policy. -->
        <exclude name="SlevomatCodingStandard.TypeHints.ParameterTypeHint.UselessAnnotation"/>
    </rule>
    <rule ref="SlevomatCodingStandard.TypeHints.PropertyTypeHint">
        <!-- Exclude BaseController and API controllers due to CodeIgniter parent class limitations -->
        <exclude-pattern>app/Controllers/BaseController.php</exclude-pattern>
        <exclude-pattern>app/Controllers/Api/*Controller.php</exclude-pattern>
        <!-- Exclude test support classes - they override parent properties without type hints -->
        <exclude-pattern>tests/Support/*TestCase.php</exclude-pattern>
        <!-- Exclude AbiSageIntacct library - third-party namespace with different conventions -->
        <exclude-pattern>app/Libraries/AbiSageIntacct/*</exclude-pattern>
        <!-- CodeIgniter Model subclasses redeclare untyped parent properties
             (e.g. $table, $allowedFields, $validationRules). Adding native
             types here would break inheritance compatibility. -->
        <exclude-pattern>app/Infrastructure/Persistence/Models/*</exclude-pattern>
        <exclude-pattern>app/Models/*</exclude-pattern>
        <!-- Same rationale as Parameter/ReturnTypeHint: docblock policy mandates
             @var on every property, so "useless" duplication is by design. -->
        <exclude name="SlevomatCodingStandard.TypeHints.PropertyTypeHint.UselessAnnotation"/>
    </rule>
    <rule ref="SlevomatCodingStandard.TypeHints.ReturnTypeHint">
        <!-- Same rationale as ParameterTypeHint above: Squiz.Commenting.FunctionComment
             requires @return on every non-void method, so Slevomat's "useless"
             check on @return-that-matches-native conflicts with the docblock policy. -->
        <exclude name="SlevomatCodingStandard.TypeHints.ReturnTypeHint.UselessAnnotation"/>
    </rule>

    <!-- Discourage else (encourage early returns) -->
    <rule ref="SlevomatCodingStandard.ControlStructures.EarlyExit"/>
    <rule ref="SlevomatCodingStandard.ControlStructures.DisallowYodaComparison"/>

    <!-- Require null coalesce operator -->
    <rule ref="SlevomatCodingStandard.ControlStructures.RequireNullCoalesceOperator"/>
    <rule ref="SlevomatCodingStandard.ControlStructures.RequireNullCoalesceEqualOperator"/>

    <!-- Clean up unused code -->
    <rule ref="SlevomatCodingStandard.Functions.UnusedParameter"/>
    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
        <properties>
            <property name="searchAnnotations" value="true"/>
        </properties>
    </rule>
    <rule ref="SlevomatCodingStandard.Namespaces.UseFromSameNamespace"/>
    <rule ref="SlevomatCodingStandard.Variables.UnusedVariable"/>
    <rule ref="SlevomatCodingStandard.Variables.UselessVariable"/>

    <!-- Code quality -->
    <rule ref="SlevomatCodingStandard.Classes.ClassConstantVisibility"/>
    <rule ref="SlevomatCodingStandard.Classes.ModernClassNameReference"/>
    <rule ref="SlevomatCodingStandard.Classes.UselessLateStaticBinding"/>
    <rule ref="SlevomatCodingStandard.Commenting.EmptyComment"/>
    <rule ref="SlevomatCodingStandard.Commenting.InlineDocCommentDeclaration"/>
    <rule ref="SlevomatCodingStandard.Commenting.UselessInheritDocComment"/>
    <rule ref="SlevomatCodingStandard.ControlStructures.UselessIfConditionWithReturn"/>
    <rule ref="SlevomatCodingStandard.ControlStructures.UselessTernaryOperator"/>
    <rule ref="SlevomatCodingStandard.Exceptions.DeadCatch"/>
    <rule ref="SlevomatCodingStandard.Functions.UselessParameterDefaultValue"/>
    <rule ref="SlevomatCodingStandard.PHP.UselessParentheses"/>
    <rule ref="SlevomatCodingStandard.PHP.UselessSemicolon"/>

    <!-- Namespace and use statements -->
    <rule ref="SlevomatCodingStandard.Namespaces.AlphabeticallySortedUses"/>
    <rule ref="SlevomatCodingStandard.Namespaces.RequireOneNamespaceInFile"/>
    <rule ref="SlevomatCodingStandard.Namespaces.NamespaceDeclaration"/>
    <rule ref="SlevomatCodingStandard.Namespaces.UseSpacing">
        <properties>
            <property name="linesCountBeforeFirstUse" value="1"/>
            <property name="linesCountBetweenUseTypes" value="1"/>
            <property name="linesCountAfterLastUse" value="1"/>
        </properties>
    </rule>

    <!-- Arrays -->
    <rule ref="SlevomatCodingStandard.Arrays.TrailingArrayComma"/>

    <!-- Operators -->
    <rule ref="SlevomatCodingStandard.Operators.RequireCombinedAssignmentOperator"/>

    <!-- Type casting -->
    <rule ref="SlevomatCodingStandard.PHP.TypeCast"/>

    <!-- Modern PHP features -->
    <rule ref="SlevomatCodingStandard.Functions.StrictCall"/>
    <rule ref="SlevomatCodingStandard.PHP.ShortList"/>

    <!--
      ============================================================
      AI-first strictness (Phase 1)
      ============================================================
      These rules tighten what static analysis can prove about the
      codebase. Each one is here because AIs and IDEs benefit
      directly: tighter types = better inference, no mixed = no
      black holes, identity comparisons = no implicit coercion
      surprises, final-by-default = no silent extension contracts.
    -->

    <!-- Ban `mixed` in the DOMAIN layer. Domain code dealing in
         business concepts should never trade in untyped values. AIs
         lose most inference power on `mixed`-typed parameters/returns,
         and a domain entity accepting `mixed` is almost always a smell.

         Boundary layers (HTTP, serialization, settings, test fixtures)
         legitimately handle `mixed` because that's what crosses the
         system boundary — they're not in scope. -->
    <rule ref="SlevomatCodingStandard.TypeHints.DisallowMixedTypeHint">
        <include-pattern>app/Domain/</include-pattern>
        <!-- Ports that expose external system payloads (JWTs, webhook
             bodies, RPC envelopes) genuinely deal in heterogeneous data
             after deserialization. Converting to typed DTOs is a bigger
             refactor than this rule should force. -->
        <exclude-pattern>app/Domain/*/Ports/</exclude-pattern>
        <!-- ServiceProviders are DI container wiring; the container holds
             services of arbitrary type by design. -->
        <exclude-pattern>app/Domain/*/*ServiceProvider.php</exclude-pattern>
        <!-- Repository implementations live under app/Domain/{X}/Repositories/
             as infrastructure adapters tagged with #[InfrastructureAdapter]
             (Phase 3). They legitimately map raw DB rows (array<string, mixed>)
             into domain entities/DTOs at the persistence boundary. -->
        <exclude-pattern>app/Domain/*/Repositories/</exclude-pattern>
    </rule>

    <!-- Identity-only comparisons. `==` allows coercion surprises that
         AIs can't reason about ("0" == 0, [] == null on some PHP versions). -->
    <rule ref="SlevomatCodingStandard.Operators.DisallowEqualOperators"/>

    <!-- Every class is either `final` (default) or `abstract` (explicit
         extension contract). Forbids the "could be extended someday" hedge
         that makes inheritance silently OK throughout the codebase. -->
    <rule ref="SlevomatCodingStandard.Classes.RequireAbstractOrFinal">
        <!-- CodeIgniter framework subclasses (controllers, models) have
             to extend specific parent classes; they aren't aggregate
             leaves so we don't force `final` on them. -->
        <exclude-pattern>app/Controllers/</exclude-pattern>
        <exclude-pattern>app/Infrastructure/Persistence/Models/</exclude-pattern>
        <exclude-pattern>app/Models/</exclude-pattern>
        <exclude-pattern>app/Database/</exclude-pattern>
        <!-- EventDispatcher is non-final on purpose (mock generator) -->
        <exclude-pattern>app/Infrastructure/Bus/EventDispatcher.php</exclude-pattern>
        <!-- Legitimate concrete base classes that are BOTH instantiated
             directly AND extended. Marking them `abstract` would force
             every `throw new DomainException(...)` / `new RateLimitResult(...)`
             call site to switch to a concrete subclass; marking them
             `final` (phpcbf's auto-pick) breaks the existing subclasses. -->
        <exclude-pattern>app/Domain/Shared/Exceptions/DomainException.php</exclude-pattern>
        <exclude-pattern>app/Domain/Shared/Exceptions/ValidationException.php</exclude-pattern>
        <exclude-pattern>app/Domain/Shared/ValueObjects/RateLimitResult.php</exclude-pattern>
        <!-- Concrete classes mocked directly in tests via PHPUnit's
             createMock(). The right architectural fix is to mock the
             interface they implement, but until those tests are
             rewritten we leave the classes non-final. New code should
             prefer interface-based mocking and stay `final`. -->
        <exclude-pattern>app/Domain/Cookie/Repositories/CookieRepository.php</exclude-pattern>
        <exclude-pattern>app/Domain/User/Repositories/UserRepository.php</exclude-pattern>
        <exclude-pattern>app/Domain/User/Repositories/PasswordHistoryRepository.php</exclude-pattern>
        <exclude-pattern>app/Infrastructure/Auth/Services/PermissionService.php</exclude-pattern>
        <exclude-pattern>app/Infrastructure/Auth/Services/DatabaseTokenBlacklistService.php</exclude-pattern>
    </rule>

    <!-- `int $x = null` is a PHP 8.1+ deprecation; force `?int $x = null`. -->
    <rule ref="SlevomatCodingStandard.TypeHints.NullableTypeForNullDefaultValue"/>

    <!--
      ============================================================
      Required documentation (drives Intelephense / IDE autocomplete)
      ============================================================
      These rules MANDATE docblocks on every class, method, and
      property in production code. They do NOT apply to tests
      (test methods are self-documenting and adding @param/@return
      to every test_* method is pure ceremony).

      Why each rule:
        FunctionComment           - every function has a docblock with @param + @return
        ClassComment              - every class has a docblock describing its purpose
        VariableComment           - every property has a @var docblock for Intelephense
        FunctionCommentThrowTag   - every thrown exception has a matching @throws
        DocCommentSpacing         - tidy blank-line policy inside docblocks
    -->
    <rule ref="Squiz.Commenting.FunctionComment">
        <exclude-pattern>tests/*</exclude-pattern>
        <exclude-pattern>*/Database/Migrations/*</exclude-pattern>
        <exclude-pattern>*/Database/Seeds/*</exclude-pattern>
        <exclude-pattern>app/Infrastructure/Persistence/Models/*</exclude-pattern>
        <exclude-pattern>app/Models/*</exclude-pattern>
        <exclude-pattern>app/Libraries/AbiSageIntacct/*</exclude-pattern>
        <!-- Native typehints already carry the param/return type; we don't
             also force prose descriptions for every parameter. -->
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
        <exclude name="Squiz.Commenting.FunctionComment.EmptyThrows"/>
        <exclude name="Squiz.Commenting.FunctionComment.ScalarTypeHintMissing"/>
        <exclude name="Squiz.Commenting.FunctionComment.TypeHintMissing"/>
        <!-- These are pure-prose stylistic nags - they don't change the
             information Intelephense reads (types in @param/@return). We
             enforce that docblocks EXIST and carry types; we don't enforce
             that every English sentence ends with a period or starts capital. -->
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentNotCapital"/>
        <exclude name="Squiz.Commenting.FunctionComment.ThrowsNoFullStop"/>
        <exclude name="Squiz.Commenting.FunctionComment.ThrowsNotCapital"/>
        <!-- Allow short-form scalars in docblocks (bool/int/float/string),
             matching the native typehint conventions. Squiz defaults to
             the older long-form "boolean/integer/double" which is no longer
             idiomatic and conflicts with Slevomat's preference. -->
        <exclude name="Squiz.Commenting.FunctionComment.IncorrectTypeHint"/>
        <exclude name="Squiz.Commenting.FunctionComment.InvalidReturn"/>
        <!-- Doesn't understand generators: a function with `iterable` return
             type may legally `return;` to early-exit. -->
        <exclude name="Squiz.Commenting.FunctionComment.InvalidReturnNotVoid"/>
        <!-- Squiz's IncorrectParamVarName sniff also gets re-used to enforce
             long-form scalars in @param ("integer" not "int"). We prefer
             short forms in docblocks to match the native typehint syntax.
             True name-vs-position mismatches are still caught by
             Squiz.Commenting.FunctionComment.ParamNameNoMatch. -->
        <exclude name="Squiz.Commenting.FunctionComment.IncorrectParamVarName"/>
    </rule>

    <rule ref="Squiz.Commenting.ClassComment">
        <exclude-pattern>tests/*</exclude-pattern>
        <exclude-pattern>*/Database/Migrations/*</exclude-pattern>
        <exclude-pattern>*/Database/Seeds/*</exclude-pattern>
        <exclude-pattern>app/Libraries/AbiSageIntacct/*</exclude-pattern>
        <!-- CodeIgniter Model subclasses are framework-driven; the parent
             class already carries the canonical description. -->
        <exclude-pattern>app/Infrastructure/Persistence/Models/*</exclude-pattern>
        <exclude-pattern>app/Models/*</exclude-pattern>
    </rule>

    <rule ref="Squiz.Commenting.VariableComment">
        <exclude-pattern>tests/*</exclude-pattern>
        <exclude-pattern>*/Database/Migrations/*</exclude-pattern>
        <exclude-pattern>*/Database/Seeds/*</exclude-pattern>
        <exclude-pattern>app/Infrastructure/Persistence/Models/*</exclude-pattern>
        <exclude-pattern>app/Models/*</exclude-pattern>
        <exclude-pattern>app/Libraries/AbiSageIntacct/*</exclude-pattern>
        <!-- Same rationale as FunctionComment: keep short-form scalars. -->
        <exclude name="Squiz.Commenting.VariableComment.IncorrectVarType"/>
    </rule>

    <rule ref="Squiz.Commenting.FunctionCommentThrowTag">
        <exclude-pattern>tests/*</exclude-pattern>
        <exclude-pattern>*/Database/Migrations/*</exclude-pattern>
        <exclude-pattern>*/Database/Seeds/*</exclude-pattern>
        <exclude-pattern>app/Libraries/AbiSageIntacct/*</exclude-pattern>
        <!-- Squiz's @throws checks are simplistic: they count `throw`
             statements in the body and demand a matching @throws count.
             Re-throws (`throw $e`) and polymorphic throws via method calls
             can't be resolved without full type inference, so the count is
             unreliable. We still REQUIRE the @throws docblock structure (so
             Intelephense picks it up) but don't enforce per-statement count.
             PHPStan's `throws` rule covers the type-inference side. -->
        <exclude name="Squiz.Commenting.FunctionCommentThrowTag.Missing"/>
        <exclude name="Squiz.Commenting.FunctionCommentThrowTag.WrongNumber"/>
    </rule>

    <rule ref="SlevomatCodingStandard.Commenting.DocCommentSpacing">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
</ruleset>
