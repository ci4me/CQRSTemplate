# Auto-detect text vs binary, normalize line endings to LF on commit.
* text=auto eol=lf

# Source
*.php          text eol=lf diff=php
*.phtml        text eol=lf diff=php
*.inc          text eol=lf diff=php
*.html         text eol=lf diff=html
*.css          text eol=lf diff=css
*.scss         text eol=lf diff=css
*.js           text eol=lf
*.mjs          text eol=lf
*.ts           text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.xml          text eol=lf
*.md           text eol=lf
*.txt          text eol=lf
*.sql          text eol=lf
*.neon         text eol=lf

# Shell + config
*.sh           text eol=lf
*.bash         text eol=lf
.env*          text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf
Dockerfile     text eol=lf
*.dockerignore text eol=lf

# Windows-only scripts
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf

# Binary (no diffing, no LF normalization)
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.webp         binary
*.svg          text eol=lf
*.pdf          binary
*.zip          binary
*.gz           binary
*.tar          binary
*.7z           binary
*.phar         binary
*.woff         binary
*.woff2        binary
*.ttf          binary
*.eot          binary
*.mp3          binary
*.mp4          binary

# GitHub Linguist: keep stats focused on app code.
vendor/**             linguist-vendored
public/**.css         linguist-vendored
public/**.js          linguist-vendored
build/**              linguist-generated
writable/**           linguist-generated
tests/**              linguist-detectable
*.md                  linguist-documentation
docs/**               linguist-documentation
.claude/**            linguist-documentation
.history/**           linguist-generated

# Don't ship dev/test infrastructure in `git archive` tarballs.
/.github           export-ignore
/.githooks         export-ignore
/.gitattributes    export-ignore
/.gitignore        export-ignore
/.editorconfig     export-ignore
/.gitmessage       export-ignore
/.claude           export-ignore
/.serena           export-ignore
/.history          export-ignore
/.vscode           export-ignore
/.mcp.json         export-ignore
/tests             export-ignore
/temp              export-ignore
/phpcs.xml         export-ignore
/phpstan.neon      export-ignore
/phpstan-bootstrap.php export-ignore
/phpunit.xml.dist  export-ignore
