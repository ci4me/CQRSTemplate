{
    "name": "ci4me/cqrs-template",
    "description": "CodeIgniter 4 CQRS + DDD project template",
    "license": "MIT",
    "type": "project",
    "homepage": "https://github.com/ci4me/CQRSTemplate",
    "support": {
        "source": "https://github.com/ci4me/CQRSTemplate",
        "issues": "https://github.com/ci4me/CQRSTemplate/issues"
    },
    "require": {
        "php": "^8.3",
        "codeigniter4/framework": "^4.0",
        "firebase/php-jwt": "^7.0",
        "monolog/monolog": "^3.9"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mikey179/vfsstream": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.5.8",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/Support",
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@setup-hooks"
        ],
        "post-update-cmd": [
            "@setup-hooks"
        ],
        "setup-hooks": "@php -r \"if (PHP_OS_FAMILY === 'Windows') { passthru('bash bin/setup-hooks'); } else { passthru('./bin/setup-hooks'); }\"",
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "test:clover": "phpunit --coverage-clover=coverage.xml",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "gitleaks": "@php -r \"passthru('command -v gitleaks >/dev/null 2>&1 && gitleaks detect --no-banner --redact --staged || echo gitleaks-not-installed-skipping');\"",
        "check": [
            "@phpstan",
            "@phpcs",
            "@test"
        ],
        "ci": [
            "@phpstan",
            "@phpcs",
            "@test:clover"
        ]
    },
    "scripts-descriptions": {
        "setup-hooks": "Wire .githooks/ as core.hooksPath (idempotent; runs automatically on install/update).",
        "check": "Run PHPStan + PHPCS + PHPUnit locally before pushing.",
        "ci": "CI variant of check (with Clover coverage output)."
    }
}
