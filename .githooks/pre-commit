#!/usr/bin/env bash
# pre-commit: format, lint, and statically check staged PHP only.
# Skip with `git commit --no-verify` (use sparingly).
set -euo pipefail

RED=$'\033[31m'; GRN=$'\033[32m'; YLW=$'\033[33m'; DIM=$'\033[2m'; RST=$'\033[0m'

# 1a. Block obvious secret-shaped *filenames* before content-scanning.
#    .env (no suffix) and .env.<word> (no further dot) — keeps .env.example, .env.dist allowed
#    because those are CONVENTIONALLY public templates.
if git diff --cached --name-only --diff-filter=ACM \
    | grep -E '(^|/)(\.env|\.env\.(local|production|prod|dev|development|staging|test))$|(^|/)secrets/|\.pem$|\.p12$|\.key$' >/dev/null; then
    echo "${RED}✗ Refusing to commit secret-looking files (.env*, secrets/, *.pem, *.p12, *.key).${RST}"
    echo "  Unstage them: git restore --staged <file>"
    exit 1
fi

# 1b. Content-level secret scan with gitleaks (real entropy + provider regexes).
#    Skips silently if gitleaks isn't installed locally — CI catches it either way.
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --redact --no-banner --config .gitleaks.toml; then
        echo "${RED}✗ gitleaks detected secrets in staged changes.${RST}"
        echo "  Review the report above. If a finding is a false positive,"
        echo "  add it to .gitleaks.toml allowlist (don't suppress per-line)."
        exit 1
    fi
else
    echo "${DIM}gitleaks not installed — skipping content-level secret scan (CI will still run it).${RST}"
fi

# 2. Detect committing-to-main (warn, don't block — main may be intentional on this repo).
branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "DETACHED")
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
    echo "${YLW}⚠ Committing directly to ${branch}. Prefer a feature branch + PR.${RST}"
fi

# 3. Collect staged PHP files only (ACM = added, copied, modified).
mapfile -t php_files < <(git diff --cached --name-only --diff-filter=ACMR -- '*.php' || true)

if [ ${#php_files[@]} -eq 0 ]; then
    echo "${DIM}pre-commit: no staged PHP files — skipping PHP checks.${RST}"
    exit 0
fi

echo "${DIM}pre-commit: checking ${#php_files[@]} staged PHP file(s)…${RST}"

# 4. Lint syntax (cheap, fast).
for f in "${php_files[@]}"; do
    if ! php -l "$f" >/dev/null 2>&1; then
        echo "${RED}✗ PHP syntax error in $f${RST}"
        php -l "$f"
        exit 1
    fi
done

# 5. PHPCS (Slevomat + PSR-12) — auto-fix with phpcbf, then re-check.
if [ -x vendor/bin/phpcs ]; then
    if ! vendor/bin/phpcs --colors -q "${php_files[@]}"; then
        echo "${YLW}phpcs failed — running phpcbf to auto-fix…${RST}"
        vendor/bin/phpcbf -q "${php_files[@]}" || true
        # Re-stage any fixes phpcbf made.
        git add "${php_files[@]}"
        if ! vendor/bin/phpcs --colors -q "${php_files[@]}"; then
            echo "${RED}✗ phpcs still failing after phpcbf. Fix manually and re-commit.${RST}"
            exit 1
        fi
        echo "${GRN}✓ phpcbf auto-fixed staged files (re-staged).${RST}"
    fi
else
    echo "${DIM}vendor/bin/phpcs not installed — skipping coding-standards check.${RST}"
fi

# 6. PHPStan Level 8 — run the project analysis (not per-file) so that
#    cross-file relationships (traits, interfaces, providers, service maps)
#    are visible. Per-file isolation produces false positives on properties
#    that are only read by traits/providers in sibling files.
#    Skip entirely when no staged PHP file falls under phpstan.neon's paths.
has_analysed_files=0
for f in "${php_files[@]}"; do
    case "$f" in
        app/Domain/*|app/Infrastructure/*|app/Libraries/*|app/Models/*|app/Controllers/*)
            case "$f" in
                app/Infrastructure/Persistence/*) ;; # excluded by phpstan.neon
                *) has_analysed_files=1 ;;
            esac
            ;;
    esac
done

if [ -x vendor/bin/phpstan ] && [ $has_analysed_files -eq 1 ]; then
    if ! vendor/bin/phpstan analyse --no-progress --memory-limit=512M; then
        echo "${RED}✗ PHPStan Level 8 found issues. Fix or commit with --no-verify (NOT recommended).${RST}"
        exit 1
    fi
elif [ ! -x vendor/bin/phpstan ]; then
    echo "${DIM}vendor/bin/phpstan not installed — skipping static analysis.${RST}"
else
    echo "${DIM}pre-commit: no staged PHP files under analysed paths — skipping PHPStan.${RST}"
fi

echo "${GRN}✓ pre-commit passed.${RST}"
